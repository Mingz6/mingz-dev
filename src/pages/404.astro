---
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
---

<PageLayout title="Not found" description="That page doesn't exist (or it moved). Try the home page or search.">
  <TopLayout>
    <div class="animate">
      <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
        404 — page not found
      </h1>
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate flex flex-col gap-4 text-black/75 dark:text-white/75">
      <p>The page you're looking for doesn't exist, or got moved during a rewrite.</p>
      <p>A few places that probably still work:</p>
      <ul class="list-disc pl-6 flex flex-col gap-1">
        <li><a class="underline hover:text-black dark:hover:text-white" href="/">Home</a></li>
        <li><a class="underline hover:text-black dark:hover:text-white" href="/blog">Blog</a></li>
        <li><a class="underline hover:text-black dark:hover:text-white" href="/projects">Projects</a></li>
        <li><a class="underline hover:text-black dark:hover:text-white" href="/search">Search</a></li>
      </ul>
    </div>
  </BottomLayout>
</PageLayout>
