---
import PageLayout from "@layouts/PageLayout.astro"
import { SOCIALS } from "@consts"
---

<PageLayout title="Resume" description="Mingzhi Zhu — Senior Software Engineer — AI & Cloud">
  <meta slot="head" name="robots" content="noindex, nofollow" />
  
  <div class="pt-36 pb-16">
    <div class="mx-auto max-w-screen-md px-5">
      <div class="animate">

        <!-- Header -->
        <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-8">
          <div>
            <h1 class="text-3xl font-bold text-black dark:text-white">Mingzhi Zhu</h1>
            <p class="text-lg opacity-75 mt-1">Senior Software Engineer — AI & Cloud</p>
          </div>
          <div class="flex flex-col items-end gap-2">
            <div class="flex gap-3">
              {SOCIALS.map(social => (
                <a href={social.HREF} target="_blank" rel="noopener noreferrer" 
                   class="text-sm underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-accent-1 dark:hover:decoration-accent-2 text-black dark:text-white blend">
                  {social.NAME}
                </a>
              ))}
              <a href="https://mingz.dev" class="text-sm underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-accent-1 dark:hover:decoration-accent-2 text-black dark:text-white blend">
                mingz.dev
              </a>
            </div>
            <button onclick="window.print()" class="print:hidden text-xs px-3 py-1 rounded border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/10 text-black dark:text-white blend cursor-pointer">
              Save as PDF
            </button>
          </div>
        </div>

        <!-- Summary -->
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-black dark:text-white border-b border-black/10 dark:border-white/10 pb-1 mb-3">Summary</h2>
          <p class="text-sm leading-relaxed">
            Senior software engineer with 12+ years delivering enterprise applications, cloud infrastructure, and AI systems. 
            Deep experience in .NET, React, and Azure. Currently building AI agents, MCP servers, and LLM-powered tools — 
            applying production engineering discipline to the AI layer.
          </p>
        </section>

        <!-- Skills -->
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-black dark:text-white border-b border-black/10 dark:border-white/10 pb-1 mb-3">Skills</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
            <div><b>Core:</b> C#, .NET, React, TypeScript, Python, Azure, SQL Server</div>
            <div><b>AI & Cloud:</b> Azure OpenAI, LLMs, MCP, RAG, Azure AI Document Intelligence/OCR, FastAPI, Bicep</div>
            <div><b>Secondary:</b> AWS (S3, Lambda, Cognito, RDS), Dapper, Entity Framework, Tailwind CSS, Nx, Docker, GitHub Actions, Microsoft Graph, Grafana</div>
            <div><b>Historical:</b> SSRS, T-SQL reporting, VBA/Excel automation, VB.NET, Lua, Google Apps Script</div>
          </div>
        </section>

        <!-- Experience -->
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-black dark:text-white border-b border-black/10 dark:border-white/10 pb-1 mb-3">Experience</h2>
          
          <div class="space-y-6">
            <div>
              <div class="flex justify-between items-baseline">
                <h3 class="font-semibold text-black dark:text-white">Full-Stack Developer</h3>
                <span class="text-xs opacity-50 shrink-0 ml-4">Sep 2021 – Present</span>
              </div>
              <p class="text-sm opacity-75">College & Association of Registered Nurses of Alberta (CRNA)</p>
              <ul class="text-sm mt-2 space-y-1 list-disc list-inside opacity-85">
                <li>Built Azure AI document intelligence solutions to automate document processing workflows</li>
                <li>Develop Teams tab apps with custom SSO, Copilot integrations, and AI-powered user workflows</li>
                <li>Build and maintain web apps using Nx, React (frontend) and C# Azure Function Apps (backend)</li>
                <li>Run CI/CD with Azure DevOps, GitHub Actions, and Bicep IaC</li>
                <li>Maintain SharePoint sites and integrations using PnP Framework and Microsoft Graph APIs</li>
                <li>Set up Azure Alerts and monitoring for production system stability</li>
              </ul>
            </div>

            <div>
              <div class="flex justify-between items-baseline">
                <h3 class="font-semibold text-black dark:text-white">Consultant — Application Developer</h3>
                <span class="text-xs opacity-50 shrink-0 ml-4">Mar 2019 – Sep 2021</span>
              </div>
              <p class="text-sm opacity-75">CGI — AB Justice AMS</p>
              <ul class="text-sm mt-2 space-y-1 list-disc list-inside opacity-85">
                <li>Developed and maintained C# applications — system performance, enhancements, mission-critical features</li>
                <li>Worked in agile teams on mission-critical apps using Microsoft technologies</li>
                <li>Built and maintained Grafana monitoring dashboards for production systems</li>
                <li>Collaborated with developers, BAs, and architects on new software delivery</li>
                <li>Developed SSRS data reports and investigated data-related issues</li>
              </ul>
            </div>

            <div>
              <div class="flex justify-between items-baseline">
                <h3 class="font-semibold text-black dark:text-white">Application Analyst</h3>
                <span class="text-xs opacity-50 shrink-0 ml-4">Nov 2014 – Mar 2019</span>
              </div>
              <p class="text-sm opacity-75">Alcanna Inc.</p>
              <ul class="text-sm mt-2 space-y-1 list-disc list-inside opacity-85">
                <li>Maintained and tested web application modules using ASP.NET MVC, Entity Framework, jQuery</li>
                <li>Developed stored procedures, SSRS reports, and real-time integration systems (Web API + T-SQL)</li>
                <li>Designed and maintained Excel macros for ERP system (Dynamics Great Plains)</li>
                <li>Communicated with business clients and vendor partners for troubleshooting and solution design</li>
              </ul>
            </div>

            <div>
              <div class="flex justify-between items-baseline">
                <h3 class="font-semibold text-black dark:text-white">System Analyst</h3>
                <span class="text-xs opacity-50 shrink-0 ml-4">Sep 2013 – Aug 2014</span>
              </div>
              <p class="text-sm opacity-75">City of Edmonton</p>
              <ul class="text-sm mt-2 space-y-1 list-disc list-inside opacity-85">
                <li>System admin for enterprise financial applications (fines, tickets, cashier systems)</li>
                <li>Performed QA activities and coordinated application testing</li>
                <li>Provided IT support and feasibility estimates for customer service requests</li>
              </ul>
            </div>

            <div>
              <div class="flex justify-between items-baseline">
                <h3 class="font-semibold text-black dark:text-white">Enterprise Application Specialist</h3>
                <span class="text-xs opacity-50 shrink-0 ml-4">Jan 2012 – Jul 2013</span>
              </div>
              <p class="text-sm opacity-75">City of Edmonton</p>
              <ul class="text-sm mt-2 space-y-1 list-disc list-inside opacity-85">
                <li>Maintained enterprise applications — SAP, SharePoint, Google Apps, Remedy, iNovah</li>
                <li>Developed Google Sites using Google Scripts and JavaScript</li>
                <li>Participated in UAT and application debugging</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Education -->
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-black dark:text-white border-b border-black/10 dark:border-white/10 pb-1 mb-3">Education</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-baseline">
              <div>
                <p class="font-semibold text-black dark:text-white text-sm">MSc Computer Science — Multimedia Specialization</p>
                <p class="text-sm opacity-75">University of Alberta</p>
              </div>
              <span class="text-xs opacity-50 shrink-0 ml-4">2021</span>
            </div>
            <div class="flex justify-between items-baseline">
              <div>
                <p class="font-semibold text-black dark:text-white text-sm">Bachelor of Technology — Technology Management</p>
                <p class="text-sm opacity-75">NAIT</p>
              </div>
              <span class="text-xs opacity-50 shrink-0 ml-4">2017</span>
            </div>
            <div class="flex justify-between items-baseline">
              <div>
                <p class="font-semibold text-black dark:text-white text-sm">Diploma — Digital Media & IT, Computer Programming</p>
                <p class="text-sm opacity-75">NAIT</p>
              </div>
              <span class="text-xs opacity-50 shrink-0 ml-4">2012</span>
            </div>
          </div>
        </section>

        <!-- Certifications -->
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-black dark:text-white border-b border-black/10 dark:border-white/10 pb-1 mb-3">Certifications</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-1 text-sm">
            <div><b>Azure AI Engineer Associate (AI-102)</b></div>
            <div>Azure AI Fundamentals (AI-900)</div>
            <div>ITIL Foundation Certificate</div>
            <div>Coursera — Machine Learning</div>
            <div>Coursera — Deep Learning Specialization</div>
          </div>
        </section>

      </div>
    </div>
  </div>
</PageLayout>
