---
type Props = {
  text: string
  icon: string
  href: string
}

const { text, icon, href } = Astro.props
---

<a href={href} target="_blank" class="w-fit px-3 py-2 group rounded-xl glass flex gap-2 items-center hover:bg-accent-1/5 hover:dark:bg-accent-1/10 blend">
  <svg height={20} width={20}>
    <use href={`/stack.svg#${icon}`}></use>
  </svg>
  <span class="text-sm capitalize text-neutral-500 dark:text-neutral-400 group-hover:text-accent-1 group-hover:dark:text-accent-2 blend">
    {text}
  </span>
</a>